              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Has data array', () => pm.expect(json.data).to.be.an('array'));",
                "if (json.data.length > 0) {",
                "  pm.collectionVariables.set('feeStructureId', json.data[0].id);",
                "  pm.test('Fee structure has fields', () => {",
                "    pm.expect(json.data[0]).to.have.property('name');",
                "    pm.expect(json.data[0]).to.have.property('amount');",
                "    pm.expect(json.data[0]).to.have.property('currency');",
                "  });",
                "}"
              ]
            }
          }]
        },
        {
          "name": "POST /billing/fee-structures — Create",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/billing/fee-structures",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Test Fee\", \"amount\": 1500, \"currency\": \"MAD\", \"frequency\": \"monthly\", \"due_day\": 5}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201 or 200', () => pm.expect([200, 201]).to.include(pm.response.code));",
                "const json = pm.response.json();",
                "if (json.data) pm.collectionVariables.set('feeStructureId', json.data.id);"
              ]
            }
          }]
