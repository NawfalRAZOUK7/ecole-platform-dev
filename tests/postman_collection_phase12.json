{
  "info": {
    "name": "École Platform — Phase 12A/12B/12C API Tests",
    "description": "Comprehensive API test collection for timetable, billing, messaging, announcements, and progress endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000/api/v1" },
    { "key": "adminToken", "value": "" },
    { "key": "teacherToken", "value": "" },
    { "key": "parentToken", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "schoolId", "value": "" },
    { "key": "classId", "value": "" },
    { "key": "studentId", "value": "" },
    { "key": "conversationId", "value": "" },
    { "key": "feeStructureId", "value": "" },
    { "key": "invoiceId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{adminToken}}" }]
  },
  "item": [
    {
      "name": "00 — Auth Setup",
      "item": [
        {
          "name": "Login as ADM",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@school.ma\", \"password\": \"AdminPass123!\", \"school_slug\": \"demo-school\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Admin login 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('adminToken', json.data.access_token);",
                "pm.collectionVariables.set('schoolId', json.data.user.school_id);"
              ]
            }
          }]
        },
        {
          "name": "Login as TCH",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"teacher@school.ma\", \"password\": \"TeacherPass123!\", \"school_slug\": \"demo-school\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Teacher login 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('teacherToken', json.data.access_token);"
              ]
            }
          }]
        },
        {
          "name": "Login as PAR",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"parent@school.ma\", \"password\": \"ParentPass123!\", \"school_slug\": \"demo-school\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Parent login 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('parentToken', json.data.access_token);"
              ]
            }
          }]
        },
        {
          "name": "Login as STD",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"student@school.ma\", \"password\": \"StudentPass123!\", \"school_slug\": \"demo-school\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Student login 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('studentToken', json.data.access_token);",
                "pm.collectionVariables.set('studentId', json.data.user.id);"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "01 — Timetable (Phase 12A/12B)",
      "item": [
        {
          "name": "GET /timetable/me/weekly — Student weekly schedule",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/timetable/me/weekly",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Has data.slots array', () => pm.expect(json.data).to.have.property('slots'));",
                "pm.test('Has week_start', () => pm.expect(json.data).to.have.property('week_start'));",
                "pm.test('Has week_end', () => pm.expect(json.data).to.have.property('week_end'));",
                "if (json.data.slots.length > 0) {",
                "  const slot = json.data.slots[0];",
                "  pm.test('Slot has required fields', () => {",
                "    pm.expect(slot).to.have.property('day_of_week');",
                "    pm.expect(slot).to.have.property('start_time');",
                "    pm.expect(slot).to.have.property('end_time');",
                "    pm.expect(slot).to.have.property('subject');",
                "  });",
                "}"
              ]
            }
          }]
        },
        {
          "name": "POST /timetable/slots — ADM create slot",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/timetable/slots",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"class_id\": \"{{classId}}\", \"day_of_week\": 1, \"start_time\": \"08:00:00\", \"end_time\": \"09:00:00\", \"subject\": \"Math\", \"is_recurring\": true}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201 or 200', () => pm.expect([200, 201]).to.include(pm.response.code));"
              ]
            }
          }]
        },
        {
          "name": "GET /timetable/me/weekly — Forbidden for unauthenticated",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/timetable/me/weekly",
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 401', () => pm.response.to.have.status(401));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "02 — Billing (Phase 12A)",
      "item": [
        {
          "name": "GET /billing/fee-structures — List",
          "request": {
