          "name": "POST /billing/generate-invoices — Generate",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/billing/generate-invoices",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"fee_structure_id\": \"{{feeStructureId}}\", \"period_id\": \"2025-01\", \"issued_date\": \"2025-01-01\", \"due_date\": \"2025-01-15\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Has generated count', () => pm.expect(json.data).to.have.property('generated'));"
              ]
            }
          }]
        },
        {
          "name": "GET /billing/fee-structures — TCH forbidden",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/billing/fee-structures",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{teacherToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 403', () => pm.response.to.have.status(403));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "03 — Messaging (Phase 12A/12B)",
      "item": [
        {
          "name": "GET /messages/conversations — List",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/messages/conversations?limit=20", "host": ["{{baseUrl}}"], "path": ["messages", "conversations"], "query": [{ "key": "limit", "value": "20" }] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Has data array', () => pm.expect(json.data).to.be.an('array'));",
                "pm.test('Has meta pagination', () => pm.expect(json.meta).to.have.property('has_more'));",
                "if (json.data.length > 0) {",
                "  pm.collectionVariables.set('conversationId', json.data[0].id);",
                "  pm.test('Conversation has fields', () => {",
                "    pm.expect(json.data[0]).to.have.property('type');",
                "    pm.expect(json.data[0]).to.have.property('participants');",
                "  });",
                "}"
              ]
            }
          }]
        },
        {
          "name": "POST /messages/conversations — Create DIRECT",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/messages/conversations",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"type\": \"DIRECT\", \"participant_ids\": [\"{{studentId}}\"], \"subject\": \"Test conversation\", \"initial_message\": \"Hello from Postman test\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201 or 200', () => pm.expect([200, 201]).to.include(pm.response.code));",
                "const json = pm.response.json();",
                "if (json.data) pm.collectionVariables.set('conversationId', json.data.id);"
              ]
            }
          }]
        },
        {
          "name": "GET /messages/conversations/:id/messages — List messages",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/messages/conversations/{{conversationId}}/messages?limit=50",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Has data array', () => pm.expect(json.data).to.be.an('array'));",
                "if (json.data.length > 0) {",
                "  pm.test('Message has fields', () => {",
                "    pm.expect(json.data[0]).to.have.property('body');",
                "    pm.expect(json.data[0]).to.have.property('sender_id');",
                "    pm.expect(json.data[0]).to.have.property('sent_at');",
                "  });",
                "}"
              ]
            }
          }]
        },
        {
          "name": "POST /messages/conversations/:id/messages — Send message",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/messages/conversations/{{conversationId}}/messages",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"body\": \"Test message from Postman\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201 or 200', () => pm.expect([200, 201]).to.include(pm.response.code));",
                "const json = pm.response.json();",
                "pm.test('Message returned', () => pm.expect(json.data).to.have.property('id'));"
              ]
            }
          }]
        },
        {
          "name": "POST /messages/conversations/:id/read — Mark as read",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/messages/conversations/{{conversationId}}/read",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"message_id\": \"latest\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200 or 204', () => pm.expect([200, 204]).to.include(pm.response.code));"
              ]
            }
          }]
        }
      ]
    },
