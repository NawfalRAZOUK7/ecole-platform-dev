          "name": "GET /invoices — PAR list",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/invoices?limit=20",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] }
          },
          "event": [{
            "listen": "test",
