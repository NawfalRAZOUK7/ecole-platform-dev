        {
          "name": "POST /billing/fee-assignments — Assign",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/billing/fee-assignments",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"fee_structure_id\": \"{{feeStructureId}}\", \"student_id\": \"{{studentId}}\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200 or 201', () => pm.expect([200, 201]).to.include(pm.response.code));"
              ]
            }
          }]
