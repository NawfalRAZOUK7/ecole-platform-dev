            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"invoice_id\": \"{{invoiceId}}\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200 or 400 (no overdue)', () => pm.expect([200, 400]).to.include(pm.response.code));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "06 — Progress (Phase 12C)",
      "item": [
        {
          "name": "GET /progress/me — Student own progress",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/progress/me",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Has grade_trends', () => pm.expect(json.data).to.have.property('grade_trends'));",
                "pm.test('Has content_completion', () => pm.expect(json.data).to.have.property('content_completion'));",
                "pm.test('Has activity_scores', () => pm.expect(json.data).to.have.property('activity_scores'));",
                "pm.test('Has attendance', () => pm.expect(json.data).to.have.property('attendance'));",
                "pm.test('Has assessment_results', () => pm.expect(json.data).to.have.property('assessment_results'));",
                "pm.test('grade_trends has labels+datasets', () => {",
                "  pm.expect(json.data.grade_trends).to.have.property('labels');",
                "  pm.expect(json.data.grade_trends).to.have.property('datasets');",
                "});",
                "pm.test('content_completion has summary', () => {",
                "  pm.expect(json.data.content_completion).to.have.property('summary');",
                "  pm.expect(json.data.content_completion.summary).to.have.property('completion_rate');",
                "});",
                "pm.test('attendance has overview with summary', () => {",
                "  pm.expect(json.data.attendance.overview).to.have.property('summary');",
                "  pm.expect(json.data.attendance.overview.summary).to.have.property('attendance_rate');",
                "});"
              ]
            }
          }]
        },
        {
          "name": "GET /progress/student/:id — PAR views child",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/progress/student/{{studentId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Has student_name', () => pm.expect(json.data).to.have.property('student_name'));",
                "pm.test('Has all chart sections', () => {",
                "  pm.expect(json.data).to.have.property('grade_trends');",
                "  pm.expect(json.data).to.have.property('content_completion');",
                "  pm.expect(json.data).to.have.property('activity_scores');",
                "  pm.expect(json.data).to.have.property('attendance');",
                "});"
              ]
            }
          }]
        },
        {
          "name": "GET /progress/student/:id — STD cannot view other student",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/progress/student/00000000-0000-0000-0000-000000000000",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 403', () => pm.response.to.have.status(403));"
              ]
            }
          }]
        },
        {
          "name": "GET /progress/children — PAR overview",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/progress/children",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Has children array', () => pm.expect(json.data).to.have.property('children'));",
                "pm.test('Has charts.comparison', () => pm.expect(json.data.charts).to.have.property('comparison'));",
                "if (json.data.children.length > 0) {",
                "  pm.test('Child has metrics', () => {",
                "    pm.expect(json.data.children[0]).to.have.property('grade_average');",
                "    pm.expect(json.data.children[0]).to.have.property('attendance_rate');",
                "    pm.expect(json.data.children[0]).to.have.property('content_completion_rate');",
                "  });",
                "}"
              ]
            }
          }]
        },
        {
          "name": "GET /progress/children — STD forbidden",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/progress/children",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 403', () => pm.response.to.have.status(403));"
              ]
            }
          }]
        },
        {
          "name": "GET /progress/class/:id — TCH class progress",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/progress/class/{{classId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{teacherToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Has class_averages', () => pm.expect(json.data).to.have.property('class_averages'));",
                "pm.test('Has students array', () => pm.expect(json.data).to.have.property('students'));",
                "pm.test('Has charts', () => pm.expect(json.data).to.have.property('charts'));",
                "pm.test('class_averages has fields', () => {",
                "  pm.expect(json.data.class_averages).to.have.property('grade_average');",
                "  pm.expect(json.data.class_averages).to.have.property('attendance_rate');",
                "});"
              ]
            }
          }]
        },
        {
          "name": "GET /progress/class/:id — PAR forbidden",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/progress/class/{{classId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 403', () => pm.response.to.have.status(403));"
              ]
            }
          }]
        }
      ]
    }
  ]
