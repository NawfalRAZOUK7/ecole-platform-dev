{
  "info": {
    "name": "École Platform — Phase 13 Notifications Center",
    "description": "Postman collection for notification center, preferences, digest, and device token flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000/api/v1" },
    { "key": "schoolId", "value": "00000000-0000-4000-8000-000000000001" },
    { "key": "studentId", "value": "10000000-0000-4000-8000-000000000007" },
    { "key": "adminToken", "value": "" },
    { "key": "parentToken", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "deviceId", "value": "" }
  ],
  "item": [
    {
      "name": "00 — Auth Setup",
      "item": [
        {
          "name": "Login as ADM",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@ecole-benani.ma\",\"password\":\"admin123\",\"school_id\":\"{{schoolId}}\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Admin login 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('adminToken', json.data.access_token);"
              ]
            }
          }]
        },
        {
          "name": "Login as PAR",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"parent.alaoui@gmail.com\",\"password\":\"parent123\",\"school_id\":\"{{schoolId}}\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Parent login 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('parentToken', json.data.access_token);"
              ]
            }
          }]
        },
        {
          "name": "Login as STD",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"yassine.alaoui@ecole-benani.ma\",\"password\":\"student123\",\"school_id\":\"{{schoolId}}\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Student login 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('studentToken', json.data.access_token);"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "01 — Notification Hub",
      "item": [
        {
          "name": "POST /notifications/batch — ADM sends billing alert",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/notifications/batch",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"title\":\"Phase 13 Postman Billing Alert\",\"body\":\"Please review your latest invoice.\",\"category\":\"billing\",\"priority\":\"critical\",\"user_ids\":[\"{{studentId}}\"],\"action_url\":\"/billing/invoices\",\"event_ref\":\"phase13.postman\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Batch create 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Created one notification', () => pm.expect(json.data.notifications_created).to.eql(1));",
                "pm.test('Routing includes in_app', () => pm.expect(json.data.routed_channels).to.include('in_app'));"
              ]
            }
          }]
        },
        {
          "name": "GET /notifications/unread-count — Student",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/notifications/unread-count",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Unread count 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Unread count exists', () => pm.expect(json.data).to.have.property('unread_count'));"
              ]
            }
          }]
        },
        {
          "name": "GET /notifications — Student history",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/notifications?limit=5&category=billing&read=false",
              "host": ["{{baseUrl}}"],
              "path": ["notifications"],
              "query": [
                { "key": "limit", "value": "5" },
                { "key": "category", "value": "billing" },
                { "key": "read", "value": "false" }
              ]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Notification list 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('List is an array', () => pm.expect(json.data).to.be.an('array'));",
                "if (json.data.length > 0) { pm.collectionVariables.set('notificationId', json.data[0].id); }"
              ]
            }
          }]
        },
        {
          "name": "PATCH /notifications/{id}/read — Student mark read",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/notifications/{{notificationId}}/read",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"read\": true}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Mark read 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Notification is read', () => pm.expect(json.data.read).to.eql(true));"
              ]
            }
          }]
        },
        {
          "name": "PATCH /notifications/mark-all-read — Student",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/notifications/mark-all-read",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Mark all read 200', () => pm.response.to.have.status(200));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "02 — Preferences & Digest",
      "item": [
        {
          "name": "GET /notifications/preferences — Parent",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/notifications/preferences",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Preferences 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Preferences array exists', () => pm.expect(json.data.preferences).to.be.an('array'));"
              ]
            }
          }]
        },
        {
          "name": "POST /notifications/digest/preferences — Parent weekly",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/notifications/digest/preferences",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"digest_frequency\":\"weekly\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Digest update 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Digest frequency saved', () => pm.expect(json.data.digest_frequency).to.eql('weekly'));"
              ]
            }
          }]
        },
        {
          "name": "POST /notifications/digest/preferences — Student forbidden",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/notifications/digest/preferences",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"digest_frequency\":\"daily\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Student digest is forbidden', () => pm.response.to.have.status(403));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "03 — Devices",
      "item": [
        {
          "name": "POST /devices/register — Parent",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/devices/register",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"token\":\"phase13-postman-device-token-abcdefghijklmnopqrstuvwxyz\",\"platform\":\"android\",\"device_name\":\"Postman Pixel\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Device register 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('deviceId', json.data.id);"
              ]
            }
          }]
        },
        {
          "name": "GET /devices — Parent",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/devices",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Device list 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Devices array exists', () => pm.expect(json.data).to.be.an('array'));"
              ]
            }
          }]
        },
        {
          "name": "DELETE /devices/{id} — Parent",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/devices/{{deviceId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{parentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Device delete 200', () => pm.response.to.have.status(200));"
              ]
            }
          }]
        }
      ]
    }
  ]
}
