{
  "info": {
    "name": "École Platform — Phase 14 Reports & Analytics",
    "description": "Postman collection for report generation, analytics dashboard, and CSV/XLSX export flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000/api/v1" },
    { "key": "schoolId", "value": "00000000-0000-4000-8000-000000000001" },
    { "key": "adminToken", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "classId", "value": "" },
    { "key": "reportJobId", "value": "" }
  ],
  "item": [
    {
      "name": "00 — Auth Setup",
      "item": [
        {
          "name": "Login as ADM",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@ecole-benani.ma\",\"password\":\"admin123\",\"school_id\":\"{{schoolId}}\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Admin login 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('adminToken', json.data.access_token);"
              ]
            }
          }]
        },
        {
          "name": "Login as STD",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"yassine.alaoui@ecole-benani.ma\",\"password\":\"student123\",\"school_id\":\"{{schoolId}}\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Student login 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('studentToken', json.data.access_token);"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "01 — Reports",
      "item": [
        {
          "name": "GET /reports/options — ADM class summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reports/options?type=class_summary",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "options"],
              "query": [{ "key": "type", "value": "class_summary" }]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Report options 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Classes present', () => pm.expect(json.data.classes.length).to.be.greaterThan(0));",
                "pm.collectionVariables.set('classId', json.data.classes[0].id);"
              ]
            }
          }]
        },
        {
          "name": "POST /reports/generate — Student report card",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/reports/generate",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"type\":\"student_report_card\",\"locale\":\"fr\",\"from_date\":\"2020-01-01\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Report generate 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('reportJobId', json.data.id);"
              ]
            }
          }]
        },
        {
          "name": "GET /reports/{jobId}/status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports/{{reportJobId}}/status",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Report status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Status is valid', () => pm.expect(['pending','generating','ready','failed']).to.include(json.data.status));"
              ]
            }
          }]
        },
        {
          "name": "GET /reports — History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports?limit=5",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Report list 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('History array exists', () => pm.expect(json.data).to.be.an('array'));"
              ]
            }
          }]
        },
        {
          "name": "GET /reports/{jobId}/download",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports/{{reportJobId}}/download",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Download returns 200 or 422 while pending', () => pm.expect([200, 422]).to.include(pm.response.code));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "02 — Analytics",
      "item": [
        {
          "name": "GET /analytics/overview",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/analytics/overview?from=2020-01-01&compare=true",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "overview"],
              "query": [
                { "key": "from", "value": "2020-01-01" },
                { "key": "compare", "value": "true" }
              ]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Overview 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Metrics array exists', () => pm.expect(json.data.metrics).to.be.an('array'));"
              ]
            }
          }]
        },
        {
          "name": "GET /analytics/attendance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/analytics/attendance?period=weekly&class_id={{classId}}&from=2020-01-01",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "attendance"],
              "query": [
                { "key": "period", "value": "weekly" },
                { "key": "class_id", "value": "{{classId}}" },
                { "key": "from", "value": "2020-01-01" }
              ]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Attendance analytics 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Series array exists', () => pm.expect(json.data.series).to.be.an('array'));"
              ]
            }
          }]
        },
        {
          "name": "GET /analytics/grades",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/grades?from=2020-01-01",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Grades analytics 200', () => pm.response.to.have.status(200));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "03 — Exports",
      "item": [
        {
          "name": "GET /export/csv — Grades",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/export/csv?entity=grades&filters=%7B%22from_date%22%3A%222020-01-01%22%7D",
              "host": ["{{baseUrl}}"],
              "path": ["export", "csv"],
              "query": [
                { "key": "entity", "value": "grades" },
                { "key": "filters", "value": "{\"from_date\":\"2020-01-01\"}" }
              ]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('CSV export 200', () => pm.response.to.have.status(200));",
                "pm.test('CSV content type', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('text/csv'));"
              ]
            }
          }]
        },
        {
          "name": "GET /export/xlsx — Grades",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/export/xlsx?entity=grades&filters=%7B%22from_date%22%3A%222020-01-01%22%7D",
              "host": ["{{baseUrl}}"],
              "path": ["export", "xlsx"],
              "query": [
                { "key": "entity", "value": "grades" },
                { "key": "filters", "value": "{\"from_date\":\"2020-01-01\"}" }
              ]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('XLSX export 200', () => pm.response.to.have.status(200));",
                "pm.test('XLSX content type', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('spreadsheetml'));"
              ]
            }
          }]
        }
      ]
    }
  ]
}
