          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Parent - Admin Users Forbidden status', () => pm.expect(pm.response.code).to.be.oneOf([403]));",
              "let json = {};",
              "try { json = pm.response.json(); } catch (error) { json = {}; }",
              "pm.test('response has error', () => pm.expect(json).to.have.property('error')); "
            ]
          }
        }
