{
  "info": {
    "name": "Error Handling Validation Scenario",
    "description": "Comprehensive error path validation for all HTTP status codes and validation rules",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login for Auth Tests",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login successful - 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Save token for auth tests', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.environment.set('valid_token', jsonData.access_token);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"testuser@ecole.ma\", \"password\": \"ValidPass123!\"}"
        },
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["{{api_prefix}}", "auth", "login"]
        }
      }
    },
    {
      "name": "2. POST with Invalid JSON (Expected: 422)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Invalid JSON - 422 Unprocessable Entity', function() {",
              "  pm.expect(pm.response.code).to.equal(422);",
              "});",
              "",
              "pm.test('Response has error details', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('error');",
              "  pm.expect(jsonData).to.have.property('message');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"test@ecole.ma\", \"password\": \"pass\""
        },
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["{{api_prefix}}", "auth", "login"]
        }
      }
    },
