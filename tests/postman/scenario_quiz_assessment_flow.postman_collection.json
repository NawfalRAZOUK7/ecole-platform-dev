    {
      "name": "6. Get Question Bank Statistics",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Get statistics - 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Statistics show all question difficulties', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('total_questions');",
              "  pm.expect(jsonData).to.have.property('by_difficulty');",
              "});",
              "",
              "pm.test('Question counts are correct', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.total_questions).to.be.greaterThanOrEqual(3);",
              "  pm.expect(jsonData.by_difficulty.EASY).to.be.greaterThanOrEqual(1);",
              "  pm.expect(jsonData.by_difficulty.MEDIUM).to.be.greaterThanOrEqual(1);",
              "  pm.expect(jsonData.by_difficulty.HARD).to.be.greaterThanOrEqual(1);",
              "});"
            ]
          }
        }
      ],
