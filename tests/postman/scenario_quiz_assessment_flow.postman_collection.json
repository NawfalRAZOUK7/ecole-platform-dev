          "path": ["{{api_prefix}}", "attempts", "{{attempt_id}}", "respond"]
        }
      }
    },
    {
      "name": "16. Submit Quiz Attempt",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Quiz submitted - 200 OK or 201 Created', function() {",
              "  pm.response.to.have.status([200, 201]);",
              "});",
              "",
              "pm.test('Attempt marked as submitted', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('status');",
              "  pm.expect(jsonData.status).to.equal('SUBMITTED');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/attempts/{{attempt_id}}/submit",
          "host": ["{{base_url}}"],
          "path": ["{{api_prefix}}", "attempts", "{{attempt_id}}", "submit"]
        }
      }
    },
    {
      "name": "17. Get Attempt Results",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Results retrieved - 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Results have score and grade', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('score');",
              "  pm.expect(jsonData).to.have.property('grade');",
              "  pm.expect(jsonData).to.have.property('total_questions');",
              "});",
              "",
              "pm.test('Grade is in valid range (0-20)', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.grade).to.be.greaterThanOrEqual(0);",
              "  pm.expect(jsonData.grade).to.be.lessThanOrEqual(20);",
              "  pm.environment.set('attempt_grade', jsonData.grade);",
              "});",
              "",
              "pm.test('Score is percentage format', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.score).to.be.greaterThanOrEqual(0);",
              "  pm.expect(jsonData.score).to.be.lessThanOrEqual(100);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/attempts/{{attempt_id}}/results",
          "host": ["{{base_url}}"],
          "path": ["{{api_prefix}}", "attempts", "{{attempt_id}}", "results"]
