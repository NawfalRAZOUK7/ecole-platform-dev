              "});",
              "",
              "pm.test('Question has ID and text', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('id');",
              "  pm.expect(jsonData).to.have.property('text');",
              "  pm.environment.set('question_id_1', jsonData.id);",
              "});",
              "",
              "pm.test('Question has correct difficulty and subject', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.difficulty).to.equal('EASY');",
              "  pm.expect(jsonData.subject).to.equal('Mathematics');",
              "});"
            ]
          }
        }
