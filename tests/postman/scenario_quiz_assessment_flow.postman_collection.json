  "item": [
    {
      "name": "1. Register Teacher Account",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Teacher registration - 201 Created', function() {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Teacher user created', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.user).to.have.property('id');",
              "  pm.expect(jsonData.user.role).to.equal('TEACHER');",
              "  pm.environment.set('teacher_id', jsonData.user.id);",
              "});",
              "",
              "pm.test('Access token provided', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.environment.set('access_token', jsonData.access_token);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"{{teacher_email}}\", \"password\": \"{{teacher_password}}\", \"first_name\": \"{{teacher_first_name}}\", \"last_name\": \"{{teacher_last_name}}\", \"role\": \"TEACHER\"}"
        },
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/auth/register",
          "host": ["{{base_url}}"],
          "path": ["{{api_prefix}}", "auth", "register"]
        }
      }
    },
