{
  "info": {
    "_postman_id": "4d4be84d-6810-40dc-8687-f120ba0fc4b9",
    "name": "Ecole Platform Scenario - Student Lifecycle",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api/v1"
    },
    {
      "key": "schoolId",
      "value": "00000000-0000-4000-8000-000000000001"
    },
    {
      "key": "studentId",
      "value": "10000000-0000-4000-8000-000000000007"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "sysToken",
      "value": ""
    },
    {
      "key": "teacherToken",
      "value": ""
    },
    {
      "key": "parentToken",
      "value": ""
    },
    {
      "key": "studentToken",
      "value": ""
    },
    {
      "key": "cmsToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth - Login Student",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login Student 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.expect(json.data).to.be.an('object');",
              "pm.expect(json.data.access_token).to.be.a('string');",
              "pm.collectionVariables.set('studentToken', json.data.access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"yassine.alaoui@ecole-benani.ma\",\"password\":\"student123\",\"school_id\":\"{{schoolId}}\"}"
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "Student - Assignments",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Student - Assignments status', () => pm.expect(pm.response.code).to.be.oneOf([200]));",
              "let json = {};",
              "try { json = pm.response.json(); } catch (error) { json = {}; }",
              "pm.test('response has data', () => pm.expect(json).to.have.property('data')); "
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "url": "{{baseUrl}}/assignments"
      }
    },
    {
      "name": "Student - Quizzes",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Student - Quizzes status', () => pm.expect(pm.response.code).to.be.oneOf([200]));",
              "let json = {};",
              "try { json = pm.response.json(); } catch (error) { json = {}; }",
              "pm.test('response has data', () => pm.expect(json).to.have.property('data')); "
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "url": "{{baseUrl}}/quizzes"
      }
    },
    {
      "name": "Student - Results",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Student - Results status', () => pm.expect(pm.response.code).to.be.oneOf([200]));",
              "let json = {};",
              "try { json = pm.response.json(); } catch (error) { json = {}; }",
              "pm.test('response has data', () => pm.expect(json).to.have.property('data')); "
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "url": "{{baseUrl}}/results"
      }
    },
    {
      "name": "Student - Admin Users Forbidden",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Student - Admin Users Forbidden status', () => pm.expect(pm.response.code).to.be.oneOf([403]));",
              "let json = {};",
              "try { json = pm.response.json(); } catch (error) { json = {}; }",
              "pm.test('response has error', () => pm.expect(json).to.have.property('error')); "
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "url": "{{baseUrl}}/admin/users"
      }
    }
  ]
}
