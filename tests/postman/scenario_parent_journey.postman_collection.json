  "item": [
    {
      "name": "1. Register Parent Account",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Parent registration successful - 201 Created', function() {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has user object with ID', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('user');",
              "  pm.expect(jsonData.user).to.have.property('id');",
              "  pm.environment.set('parent_id', jsonData.user.id);",
              "});",
              "",
              "pm.test('Response has access token', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('access_token');",
              "  pm.expect(jsonData.access_token).to.be.a('string');",
              "  pm.environment.set('access_token', jsonData.access_token);",
              "});",
              "",
              "pm.test('User role is PARENT', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.user.role).to.equal('PARENT');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"{{parent_email}}\", \"password\": \"{{parent_password}}\", \"first_name\": \"{{parent_first_name}}\", \"last_name\": \"{{parent_last_name}}\", \"role\": \"PARENT\", \"phone\": \"{{profile_phone}}\"}"
        },
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/auth/register",
          "host": ["{{base_url}}"],
          "path": ["{{api_prefix}}", "auth", "register"]
        }
      }
    },
    {
      "name": "2. Login as Parent",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login successful - 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has access_token and refresh_token', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('access_token');",
              "  pm.expect(jsonData).to.have.property('refresh_token');",
              "});",
              "",
              "pm.test('Update tokens for authenticated requests', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.environment.set('access_token', jsonData.access_token);",
              "  pm.environment.set('refresh_token', jsonData.refresh_token);",
              "});"
            ]
          }
        }
      ],
