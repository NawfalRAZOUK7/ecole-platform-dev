{
  "info": {
    "name": "Program Enrollment Flow",
    "description": "Create program → version → eligibility check → enroll → assert snapshot immutability.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Create Program",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Bilingual Track Test\",\n  \"description\": \"English-French bilingual program\",\n  \"levels\": [\"CP\", \"CE1\", \"CE2\"],\n  \"is_active\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/academic/programs",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "academic", "programs"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "pm.test('Program created', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json.data).to.have.property('id');",
              "  pm.expect(json.data.levels).to.include.members(['CP', 'CE1']);",
              "  pm.environment.set('program_id', json.data.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Create Program Version",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"version_number\": 1,\n  \"effective_date\": \"2024-09-01\",\n  \"rules\": {}\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/academic/programs/{{program_id}}/versions",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "academic", "programs", "{{program_id}}", "versions"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "pm.test('Version created', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json.data).to.have.property('id');",
              "  pm.expect(json.data.version_number).to.eql(1);",
              "  pm.environment.set('version_id', json.data.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Check Eligibility",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"student_id\": \"{{student_id}}\",\n  \"target_program_id\": \"{{program_id}}\",\n  \"kind\": \"enrollment\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/academic/eligibility/check",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "academic", "eligibility", "check"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Eligibility response shape', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json.data).to.have.property('eligible');",
              "  pm.expect(json.data).to.have.property('rules');",
              "  pm.expect(json.data.rules).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "04 - Enroll Student",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"student_id\": \"{{student_id}}\",\n  \"program_id\": \"{{program_id}}\",\n  \"version_id\": \"{{version_id}}\",\n  \"class_id\": \"{{class_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/academic/enrollments",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "academic", "enrollments"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "pm.test('Enrollment created with snapshot', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json.data).to.have.property('id');",
              "  pm.expect(json.data).to.have.property('snapshot');",
              "  pm.expect(json.data.snapshot).to.have.property('program_version_id');",
              "  pm.environment.set('enrollment_id', json.data.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 - Verify Snapshot Immutability",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/academic/enrollments/{{enrollment_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "academic", "enrollments", "{{enrollment_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Snapshot preserved', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json.data.snapshot).to.not.be.undefined;",
              "  pm.expect(json.data.snapshot.program_version_id).to.eql(pm.environment.get('version_id'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
