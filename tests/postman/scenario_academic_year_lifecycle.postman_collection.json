  "item": [
    {
      "name": "1. Register Admin Account",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Admin registration successful - 201 Created', function() {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has admin user', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.user).to.have.property('id');",
              "  pm.expect(jsonData.user.role).to.equal('ADMIN');",
              "  pm.environment.set('admin_id', jsonData.user.id);",
              "});",
              "",
              "pm.test('Access token provided', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.environment.set('access_token', jsonData.access_token);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"{{admin_email}}\", \"password\": \"{{admin_password}}\", \"first_name\": \"Admin\", \"last_name\": \"User\", \"role\": \"ADMIN\"}"
        },
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/auth/register",
          "host": ["{{base_url}}"],
          "path": ["{{api_prefix}}", "auth", "register"]
        }
      }
