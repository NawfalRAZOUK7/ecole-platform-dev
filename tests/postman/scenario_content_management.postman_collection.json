  "item": [
    {
      "name": "1. Register Content Manager",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Content manager registration - 201 Created', function() {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('User has CONTENT_MANAGER role', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.user).to.have.property('id');",
              "  pm.expect(jsonData.user.role).to.equal('CONTENT_MANAGER');",
              "  pm.environment.set('content_manager_id', jsonData.user.id);",
              "});",
              "",
              "pm.test('Access token provided', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.environment.set('access_token', jsonData.access_token);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"{{content_manager_email}}\", \"password\": \"{{content_manager_password}}\", \"first_name\": \"{{content_manager_first_name}}\", \"last_name\": \"{{content_manager_last_name}}\", \"role\": \"CONTENT_MANAGER\"}"
        },
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/auth/register",
          "host": ["{{base_url}}"],
          "path": ["{{api_prefix}}", "auth", "register"]
        }
      }
    },
