    {
      "name": "6. List All CMS Content",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Get content list - 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Content list is an array', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.be.an('array');",
              "  pm.expect(jsonData.length).to.be.greaterThanOrEqual(3);",
              "});",
              "",
              "pm.test('Each content has required fields', function() {",
              "  var jsonData = pm.response.json();",
              "  jsonData.forEach(function(content) {",
              "    pm.expect(content).to.have.property('id');",
              "    pm.expect(content).to.have.property('title');",
              "    pm.expect(content).to.have.property('type');",
              "    pm.expect(content).to.have.property('subject');",
              "    pm.expect(content).to.have.property('level');",
              "  });",
              "});"
            ]
          }
        }
