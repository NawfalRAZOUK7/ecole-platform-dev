{
  "info": {
    "_postman_id": "4dc47b04-2ae5-4939-8f10-c86d907aba6b",
    "name": "Ecole Platform Scenario - Content Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api/v1"
    },
    {
      "key": "schoolId",
      "value": "00000000-0000-4000-8000-000000000001"
    },
    {
      "key": "studentId",
      "value": "10000000-0000-4000-8000-000000000007"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "sysToken",
      "value": ""
    },
    {
      "key": "teacherToken",
      "value": ""
    },
    {
      "key": "parentToken",
      "value": ""
    },
    {
      "key": "studentToken",
      "value": ""
    },
    {
      "key": "cmsToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth - Login Content Manager",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login Content Manager 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.expect(json.data).to.be.an('object');",
              "pm.expect(json.data.access_token).to.be.a('string');",
              "pm.collectionVariables.set('cmsToken', json.data.access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"cms@ecole-platform.ma\",\"password\":\"content123\",\"school_id\":\"{{schoolId}}\"}"
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "CMS - Content",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('CMS - Content status', () => pm.expect(pm.response.code).to.be.oneOf([200]));",
              "let json = {};",
              "try { json = pm.response.json(); } catch (error) { json = {}; }",
              "pm.test('response has data', () => pm.expect(json).to.have.property('data')); "
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{cmsToken}}"
          }
        ],
        "url": "{{baseUrl}}/cms/content"
      }
    },
    {
      "name": "CMS - Submissions",
      "event": [
        {
          "listen": "test",
          "script": {
