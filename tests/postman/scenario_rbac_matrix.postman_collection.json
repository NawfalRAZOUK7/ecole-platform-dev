  "item": [
    {
      "name": "SYS_ADMIN Tests",
      "item": [
        {
          "name": "SYS_ADMIN - Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('SYS_ADMIN login - 200 OK', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Save token', function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('sys_admin_token', jsonData.access_token);",
                  "  pm.environment.set('current_token', jsonData.access_token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"sysadmin@ecole.ma\", \"password\": \"SysAdminPass123!\"}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "{{api_prefix}}",
                "auth",
                "login"
              ]
            }
          }
        },
