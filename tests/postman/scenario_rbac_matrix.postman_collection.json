  "item": [
    {
      "name": "Auth - Login System Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login System Admin 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.expect(json.data).to.be.an('object');",
              "pm.expect(json.data.access_token).to.be.a('string');",
              "pm.collectionVariables.set('sysToken', json.data.access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"superadmin@ecole-platform.ma\",\"password\":\"superadmin123\",\"school_id\":\"{{schoolId}}\"}"
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "SYS - Dashboard",
