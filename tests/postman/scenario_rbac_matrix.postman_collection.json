        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('SYS - Dashboard status', () => pm.expect(pm.response.code).to.be.oneOf([200]));",
              "let json = {};",
              "try { json = pm.response.json(); } catch (error) { json = {}; }",
              "pm.test('response has data', () => pm.expect(json).to.have.property('data')); "
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
