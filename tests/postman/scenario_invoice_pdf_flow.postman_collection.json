{
  "info": {
    "name": "Invoice PDF Flow",
    "description": "Create invoice → request PDF (FR + AR) → assert HTTP 307 → fetch from MinIO.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Create Invoice",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"parent_id\": \"{{parent_id}}\",\n  \"items\": [\n    {\n      \"description\": \"Tuition September\",\n      \"amount\": 1500.0,\n      \"unit_price\": 1500.0,\n      \"quantity\": 1\n    }\n  ],\n  \"due_date\": \"2024-10-01\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/billing/invoices",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "billing", "invoices"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "pm.test('Invoice created with required fields', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json.data).to.have.property('id');",
              "  pm.expect(json.data).to.have.property('total_amount');",
              "  pm.expect(json.data).to.have.property('status');",
              "  pm.environment.set('invoice_id', json.data.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Request PDF (FR)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Accept-Language",
            "value": "fr"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/billing/invoices/{{invoice_id}}/pdf",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "billing", "invoices", "{{invoice_id}}", "pdf"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 307 redirect to PDF', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([307, 302]);",
              "  pm.expect(pm.response.to.have.header('Location'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Request PDF (AR)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Accept-Language",
            "value": "ar"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/billing/invoices/{{invoice_id}}/pdf",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "billing", "invoices", "{{invoice_id}}", "pdf"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 307 redirect to PDF (AR)', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([307, 302]);",
              "  pm.expect(pm.response.to.have.header('Location'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
