{
  "info": {
    "name": "École Platform — Phase 15 Calendar & Events",
    "description": "Postman collection for calendar events, RSVP, reminders, and signed iCal feed flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000/api/v1" },
    { "key": "schoolId", "value": "00000000-0000-4000-8000-000000000001" },
    { "key": "adminToken", "value": "" },
    { "key": "teacherToken", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "classId", "value": "" },
    { "key": "icalUrl", "value": "" }
  ],
  "item": [
    {
      "name": "00 — Auth Setup",
      "item": [
        {
          "name": "Login as ADM",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@ecole-benani.ma\",\"password\":\"admin123\",\"school_id\":\"{{schoolId}}\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Admin login 200', () => pm.response.to.have.status(200));",
                "pm.collectionVariables.set('adminToken', pm.response.json().data.access_token);"
              ]
            }
          }]
        },
        {
          "name": "Login as TCH",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"prof.math@ecole-benani.ma\",\"password\":\"teacher123\",\"school_id\":\"{{schoolId}}\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Teacher login 200', () => pm.response.to.have.status(200));",
                "pm.collectionVariables.set('teacherToken', pm.response.json().data.access_token);"
              ]
            }
          }]
        },
        {
          "name": "Login as STD",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"yassine.alaoui@ecole-benani.ma\",\"password\":\"student123\",\"school_id\":\"{{schoolId}}\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Student login 200', () => pm.response.to.have.status(200));",
                "pm.collectionVariables.set('studentToken', pm.response.json().data.access_token);"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "01 — Calendar Options",
      "item": [
        {
          "name": "GET /calendar/options",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/calendar/options",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{teacherToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Calendar options 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('icalUrl', json.data.ical_url);",
                "if (json.data.classes.length > 0) pm.collectionVariables.set('classId', json.data.classes[0].id);"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "02 — Event CRUD",
      "item": [
        {
          "name": "POST /events — Create school event",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/events",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"title_fr\":\"Phase15 Postman Event\",\"type\":\"meeting\",\"visibility\":\"school\",\"start_at\":\"2026-04-02T09:00:00Z\",\"end_at\":\"2026-04-02T10:00:00Z\",\"reminder_offsets_minutes\":[60]}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Event create 201/200', () => pm.expect([200,201]).to.include(pm.response.code));",
                "pm.collectionVariables.set('eventId', pm.response.json().data.id);"
              ]
            }
          }]
        },
        {
          "name": "GET /events",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events?from=2026-04-01&to=2026-04-30",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Event list 200', () => pm.response.to.have.status(200));",
                "pm.test('Returns array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
              ]
            }
          }]
        },
        {
          "name": "PUT /events/{id} — Update",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/events/{{eventId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"location\":\"Main hall\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Event update 200', () => pm.response.to.have.status(200));"
              ]
            }
          }]
        },
        {
          "name": "GET /events/{id}",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events/{{eventId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Event detail 200', () => pm.response.to.have.status(200));",
                "pm.test('Location updated', () => pm.expect(pm.response.json().data.location).to.eql('Main hall'));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "03 — RSVP",
      "item": [
        {
          "name": "POST /events/{id}/rsvp",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/events/{{eventId}}/rsvp",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"status\":\"attending\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('RSVP 200', () => pm.response.to.have.status(200));"
              ]
            }
          }]
        },
        {
          "name": "GET /events/{id}/rsvp",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events/{{eventId}}/rsvp",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{studentToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Own RSVP 200', () => pm.response.to.have.status(200));",
                "pm.test('Status attending', () => pm.expect(pm.response.json().data.status).to.eql('attending'));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "04 — Signed iCal Feed",
      "item": [
        {
          "name": "GET signed iCal URL without auth",
          "request": {
            "method": "GET",
            "url": "{{icalUrl}}"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('iCal feed 200', () => pm.response.to.have.status(200));",
                "pm.test('RFC markers present', () => {",
                "  const text = pm.response.text();",
                "  pm.expect(text).to.include('BEGIN:VCALENDAR');",
                "  pm.expect(text).to.include('END:VCALENDAR');",
                "});"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "99 — Cleanup",
      "item": [
        {
          "name": "DELETE /events/{id}",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/events/{{eventId}}",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Cleanup delete 200', () => pm.expect([200,404]).to.include(pm.response.code));"
              ]
            }
          }]
        }
      ]
    }
  ]
}
