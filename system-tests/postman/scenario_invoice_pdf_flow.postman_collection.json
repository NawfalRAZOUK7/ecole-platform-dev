{
  "info": {
    "name": "Invoice PDF Flow",
    "description": "Generate invoice PDF report jobs for seeded invoice data in French and Arabic.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "school_id",
      "value": "00000000-0000-4000-8000-000000000001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "invoice_id",
      "value": "40000000-0000-4000-8000-000000000001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"school_id\": \"{{school_id}}\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "var responseBody = pm.response.json();",
              "pm.test(\"Response has access_token\", function () { pm.expect(responseBody.data).to.have.property(\"access_token\"); });",
              "pm.environment.set(\"token\", responseBody.data.access_token);",
              "pm.environment.set(\"access_token\", responseBody.data.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Get Seed Invoice",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/invoices/{{invoice_id}}"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test(\"Invoice exists\", function () { pm.expect(json.data).to.have.property(\"id\", pm.environment.get(\"invoice_id\")); });"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Generate PDF (FR)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/invoices/{{invoice_id}}/pdf?language=fr"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 201\", function () { pm.response.to.have.status(201); });",
              "var json = pm.response.json();",
              "pm.test(\"Report job returned\", function () {",
              "  pm.expect(json.data).to.have.property(\"id\");",
              "  pm.expect(json.data).to.have.property(\"type\", \"invoice_pdf\");",
              "  pm.expect([\"pending\", \"generating\", \"ready\", \"failed\"]).to.include(json.data.status);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Generate PDF (AR)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/invoices/{{invoice_id}}/pdf?language=ar"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 201\", function () { pm.response.to.have.status(201); });",
              "var json = pm.response.json();",
              "pm.test(\"Arabic report job returned\", function () {",
              "  pm.expect(json.data).to.have.property(\"id\");",
              "  pm.expect(json.data).to.have.property(\"type\", \"invoice_pdf\");",
              "  pm.expect([\"pending\", \"generating\", \"ready\", \"failed\"]).to.include(json.data.status);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
