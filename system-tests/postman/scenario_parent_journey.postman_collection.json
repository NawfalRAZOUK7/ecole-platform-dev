  "item": [
    {
      "name": "Auth - Login Parent",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login Parent 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.expect(json.data).to.be.an('object');",
              "pm.expect(json.data.access_token).to.be.a('string');",
              "pm.collectionVariables.set('parentToken', json.data.access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"parent.alaoui@gmail.com\",\"password\":\"parent123\",\"school_id\":\"{{schoolId}}\"}"
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "Parent - Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Parent - Profile status', () => pm.expect(pm.response.code).to.be.oneOf([200]));",
              "let json = {};",
              "try { json = pm.response.json(); } catch (error) { json = {}; }",
              "pm.test('response has data', () => pm.expect(json).to.have.property('data')); "
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{parentToken}}"
          }
        ],
        "url": "{{baseUrl}}/me/profile"
      }
    },
