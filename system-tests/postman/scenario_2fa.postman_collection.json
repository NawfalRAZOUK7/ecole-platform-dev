                  "    const hmac = CryptoJS.HmacSHA1(CryptoJS.enc.Hex.parse(time), CryptoJS.enc.Hex.parse(hex)).toString();",
                  "    const offset = parseInt(hmac.substring(hmac.length - 1), 16);",
                  "    const otp = (parseInt(hmac.substr(offset * 2, 8), 16) & 0x7fffffff) + '';",
                  "    return leftpad(otp.substr(otp.length - 6, 6), 6, '0');",
                  "}",
                  "",
                  "const secret = pm.environment.get('totp_secret');",
                  "if (secret) {",
                  "    const code = generateTOTP(secret);",
                  "    pm.environment.set('totp_code', code);",
                  "    console.log('Generated TOTP code: ' + code);",
                  "} else {",
                  "    console.log('No totp_secret found in environment');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Cleanup",
      "item": [
        {
          "name": "Revoke all sessions (optional)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/auth/sessions"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "responseBody = pm.response.json();",
                  "sessions = responseBody.data || [];",
                  "if (sessions.length > 0) {",
                  "    sessions.forEach(function(session) {",
                  "        pm.sendRequest({",
                  "            url: pm.environment.get('baseUrl') + '/auth/sessions/' + session.session_id,",
                  "            method: 'DELETE',",
                  "            header: {",
                  "                'Authorization': 'Bearer ' + pm.environment.get('token'),",
                  "                'Content-Type': 'application/json'",
                  "            }",
                  "        }, function (err, res) {",
                  "            console.log('Revoke session ' + session.session_id + ': ' + (res ? res.code : 'failed'));",
                  "        });",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
