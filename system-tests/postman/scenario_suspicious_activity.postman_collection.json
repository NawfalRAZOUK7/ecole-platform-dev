{
  "info": {
    "name": "École Platform - Suspicious Activity Tests",
    "description": "Suspicious activity detection tests for login from new locations and devices. Note: This test requires GeoIP database to be configured.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "school_id",
      "value": "00000000-0000-4000-8000-000000000001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Login from known location/device",
      "item": [
        {
          "name": "POST /auth/login (first login)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"school_id\": \"{{school_id}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "responseBody = pm.response.json();",
                  "pm.test(\"Response has access_token\", function () {",
                  "    pm.expect(responseBody.data).to.have.property(\"access_token\");",
                  "});",
                  "",
                  "// Save token for subsequent requests",
                  "pm.environment.set(\"token\", responseBody.data.access_token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Check known locations and devices",
      "item": [
        {
          "name": "GET /auth/me (check user info)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/auth/me"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Login history check",
      "item": [
        {
          "name": "GET /auth/sessions (check sessions)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/auth/sessions"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "responseBody = pm.response.json();",
                  "pm.test(\"Response has sessions array\", function () {",
                  "    pm.expect(responseBody.data).to.be.an(\"array\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
