{
  "info": {
    "name": "Direct Upload Flow",
    "description": "End-to-end direct upload flow against the current /uploads init, complete, and status API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "school_id",
      "value": "00000000-0000-4000-8000-000000000001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "upload_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "upload_url",
      "value": "",
      "type": "string"
    },
    {
      "key": "content_item_id",
      "value": "30000000-0000-4000-8000-000000000005",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"school_id\": \"{{school_id}}\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "var responseBody = pm.response.json();",
              "pm.test(\"Response has access_token\", function () { pm.expect(responseBody.data).to.have.property(\"access_token\"); });",
              "pm.environment.set(\"token\", responseBody.data.access_token);",
              "pm.environment.set(\"access_token\", responseBody.data.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Initiate Direct Upload",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/uploads/init",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"kind\": \"content_asset\",\n  \"filename\": \"sample-document.pdf\",\n  \"mime_type\": \"application/pdf\",\n  \"size_bytes\": 330,\n  \"scope\": {\n    \"school_id\": \"{{school_id}}\",\n    \"content_item_id\": \"{{content_item_id}}\"\n  }\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test(\"Response has upload session details\", function () {",
              "  pm.expect(json.data).to.have.property(\"upload_url\");",
              "  pm.expect(json.data).to.have.property(\"upload_id\");",
              "  pm.expect(json.data).to.have.property(\"required_headers\");",
              "});",
              "pm.environment.set(\"upload_url\", json.data.upload_url);",
              "pm.environment.set(\"upload_id\", json.data.upload_id);"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - PUT File to Signed URL",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/pdf",
            "type": "text"
          }
        ],
        "body": {
          "mode": "file",
          "file": {
            "src": "system-tests/postman/fixtures/sample-document.pdf"
          }
        },
        "url": "{{upload_url}}"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Upload successful\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]); });"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Complete Upload",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/uploads/complete",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"upload_id\": \"{{upload_id}}\",\n  \"size_bytes\": 330\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 202\", function () { pm.response.to.have.status(202); });",
              "var json = pm.response.json();",
              "pm.test(\"Upload transitioned to scanning\", function () {",
              "  pm.expect(json.data).to.have.property(\"upload_id\", pm.environment.get(\"upload_id\"));",
              "  pm.expect(json.data).to.have.property(\"state\", \"scanning\");",
              "  pm.expect(json.data).to.have.property(\"status_url\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - Poll Upload Status",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/uploads/{{upload_id}}/status"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test(\"Status payload is current upload\", function () {",
              "  pm.expect(json.data).to.have.property(\"upload_id\", pm.environment.get(\"upload_id\"));",
              "  pm.expect(json.data).to.have.property(\"state\");",
              "  pm.expect([\"uploading\", \"scanning\", \"available\", \"quarantined\", \"failed\"]).to.include(json.data.state);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
