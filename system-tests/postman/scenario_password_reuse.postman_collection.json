{
  "info": {
    "name": "École Platform - Password Reuse Tests",
    "description": "Password reuse policy scenario using an isolated invited test user.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "school_id",
      "value": "00000000-0000-4000-8000-000000000001",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "invite_code",
      "value": "",
      "type": "string"
    },
    {
      "key": "password_reuse_email",
      "value": "",
      "type": "string"
    },
    {
      "key": "password_reuse_initial",
      "value": "InitialReuse123!",
      "type": "string"
    },
    {
      "key": "password_reuse_first",
      "value": "FirstReuse456!",
      "type": "string"
    },
    {
      "key": "password_reuse_second",
      "value": "SecondReuse789!",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Login Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"school_id\": \"{{school_id}}\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get(\"password_reuse_email\")) {",
              "    var runId = Date.now() + \"-\" + Math.random().toString(36).slice(2, 8);",
              "    pm.environment.set(\"password_reuse_email\", \"password.reuse+\" + runId + \"@example.com\");",
              "    pm.environment.set(\"password_reuse_initial\", \"InitialReuse123!\");",
              "    pm.environment.set(\"password_reuse_first\", \"FirstReuse456!\");",
              "    pm.environment.set(\"password_reuse_second\", \"SecondReuse789!\");",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var responseBody = pm.response.json();",
              "pm.test(\"Response has access_token\", function () {",
              "    pm.expect(responseBody.data).to.have.property(\"access_token\");",
              "});",
              "pm.environment.set(\"admin_token\", responseBody.data.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Create Invite",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/invites/create",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role_target\": \"TCH\",\n  \"expires_in_hours\": 1\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "var responseBody = pm.response.json();",
              "pm.test(\"Response has invitation code\", function () {",
              "    pm.expect(responseBody.data).to.have.property(\"code\");",
              "});",
              "pm.environment.set(\"invite_code\", responseBody.data.code);"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Register Test User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"{{invite_code}}\",\n  \"email\": \"{{password_reuse_email}}\",\n  \"full_name\": \"Scenario Tester\",\n  \"password\": \"{{password_reuse_initial}}\",\n  \"phone\": \"+212600000001\",\n  \"profile_data\": {}\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "var responseBody = pm.response.json();",
              "pm.test(\"Registration returns access_token\", function () {",
              "    pm.expect(responseBody.data).to.have.property(\"access_token\");",
              "});",
              "pm.environment.set(\"token\", responseBody.data.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Change Password First Time",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/auth/change-password",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"current_password\": \"{{password_reuse_initial}}\",\n  \"new_password\": \"{{password_reuse_first}}\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var responseBody = pm.response.json();",
              "pm.test(\"Password change successful\", function () {",
              "    pm.expect(responseBody.data).to.have.property(\"message\");",
              "    pm.expect(responseBody.data.message).to.include(\"Password changed\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - Change Password Second Time",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/auth/change-password",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"current_password\": \"{{password_reuse_first}}\",\n  \"new_password\": \"{{password_reuse_second}}\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var responseBody = pm.response.json();",
              "pm.test(\"Password change successful\", function () {",
              "    pm.expect(responseBody.data).to.have.property(\"message\");",
              "    pm.expect(responseBody.data.message).to.include(\"Password changed\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - Attempt to Reuse Recent Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/auth/change-password",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"current_password\": \"{{password_reuse_second}}\",\n  \"new_password\": \"{{password_reuse_first}}\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 422\", function () {",
              "    pm.response.to.have.status(422);",
              "});",
              "",
              "var responseBody = pm.response.json();",
              "pm.test(\"Response has password reuse error\", function () {",
              "    pm.expect(responseBody).to.have.property(\"error\");",
              "    pm.expect(responseBody.error.message.toLowerCase()).to.include(\"password\");",
              "    pm.expect(responseBody.error.message.toLowerCase()).to.include(\"recent\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "07 - Current Password Still Works",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{password_reuse_email}}\",\n  \"password\": \"{{password_reuse_second}}\",\n  \"school_id\": \"{{school_id}}\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var responseBody = pm.response.json();",
              "pm.test(\"Response has access_token\", function () {",
              "    pm.expect(responseBody.data).to.have.property(\"access_token\");",
              "});",
              "pm.environment.set(\"token\", responseBody.data.access_token);"
            ]
          }
        }
      ]
    }
  ]
}
