# API Configuration
# Copy this file to .env and fill in the values for your environment.
# For Android emulator, use: http://10.0.2.2:8000
# For iOS simulator, use: http://localhost:8000
# For real device, use your machine's IP: http://192.168.x.x:8000
# For production, use: https://api.ecole-platform.ma
API_BASE_URL=http://localhost:8000

# Sentry error tracking (leave blank to disable)
# MOBILE_SENTRY_DSN is the canonical key (mirrors Doppler dev config).
# SENTRY_DSN is kept as a legacy fallback only.
MOBILE_SENTRY_DSN=
SENTRY_DSN=

# Runtime environment: development | staging | production
APP_ENV=development
