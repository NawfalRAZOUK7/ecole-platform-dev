{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "DB Pool Utilization (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "(db_pool_in_use / db_pool_size) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "DB Pool Size vs In Use",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "db_pool_size",
          "legendFormat": "Pool Size",
          "refId": "A"
        },
        {
          "expr": "db_pool_in_use",
          "legendFormat": "In Use",
          "refId": "B"
        },
        {
          "expr": "db_pool_overflow",
          "legendFormat": "Overflow",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Redis Cache Hit vs Miss",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(redis_hit_count[5m]))",
          "legendFormat": "Hits",
          "refId": "A"
        },
        {
          "expr": "sum(rate(redis_miss_count[5m]))",
          "legendFormat": "Misses",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Redis Hit Rate (%)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(redis_hit_count[5m])) / (sum(rate(redis_hit_count[5m])) + sum(rate(redis_miss_count[5m]))) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "title": "Redis Commands Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(redis_commands_count[5m])) by (command)",
          "legendFormat": "{{ command }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "DB Queries by Endpoint (latency)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "topk(5, histogram_quantile(0.95, sum(rate(api_request_duration_seconds_bucket{path=~\"/api/v1/(classes|enrollments|invoices|results).*\"}[5m])) by (le, path)))",
          "legendFormat": "{{ path }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ecole", "database", "redis", "infrastructure"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "DB & Redis Health",
  "uid": "ecole-db-redis-health"
}
