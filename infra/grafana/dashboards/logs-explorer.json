{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"} | json | level =~ \"$level\" [$__interval])) by (level)",
          "legendFormat": "{{ level }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80,
            "lineWidth": 0,
            "pointSize": 5,
            "barAlignment": 0
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ERROR" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "WARNING" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "INFO" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "DEBUG" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "title": "Error Rate by Service",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"} | json | level = \"ERROR\" [$__range]))",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "title": "Warning Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"} | json | level = \"WARNING\" [$__range]))",
          "legendFormat": "Warnings",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "orange", "value": 100 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "title": "Total Log Lines",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\"$service\"} [$__range]))",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "title": "Backend Logs",
      "type": "logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\"$service\"} | json | level =~ \"$level\" |= \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "Worker Logs (ARQ tasks)",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=\"worker\"} | json | level =~ \"$level\" |= \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "PostgreSQL Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 38 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\"postgres.*|db.*\"} |= \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "Redis Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 38 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\"redis.*\"} |= \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["ecole", "logs", "loki"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "type": 1, "label": "service", "stream": "" },
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "level",
        "type": "custom",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "options": [
          { "selected": false, "text": "DEBUG", "value": "DEBUG" },
          { "selected": false, "text": "INFO", "value": "INFO" },
          { "selected": false, "text": "WARNING", "value": "WARNING" },
          { "selected": false, "text": "ERROR", "value": "ERROR" },
          { "selected": false, "text": "CRITICAL", "value": "CRITICAL" }
        ],
        "query": "DEBUG,INFO,WARNING,ERROR,CRITICAL"
      },
      {
        "name": "search",
        "type": "textbox",
        "current": { "selected": false, "text": "", "value": "" },
        "label": "Search text"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Logs Explorer",
  "uid": "ecole-logs-explorer",
  "version": 1
}
