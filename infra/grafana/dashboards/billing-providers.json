{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Payment Initiations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(payment_initiated_count[5m])) by (status)",
          "legendFormat": "{{ status }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Payment Outcomes",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(payment_completed_count[24h])) by (outcome)",
          "legendFormat": "{{ outcome }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Webhook Events Received",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(webhook_received_count[5m])) by (provider, status)",
          "legendFormat": "{{ provider }} {{ status }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Webhook Signature Failures",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(webhook_signature_failures[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Billing API Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_request_duration_seconds_bucket{path=~\"/api/v1/(invoices|payments).*\"}[5m])) by (le, path))",
          "legendFormat": "{{ path }} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Payment Failure Rate (%)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(payment_completed_count{outcome=\"failed\"}[1h])) / sum(rate(payment_completed_count[1h])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ecole", "billing", "providers", "webhooks"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Billing & Providers",
  "uid": "ecole-billing-providers"
}
