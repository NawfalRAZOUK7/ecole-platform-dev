{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Login Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(auth_login_total{outcome=\"success\"}[5m])) / sum(rate(auth_login_total[5m])) * 100",
          "legendFormat": "Login Success %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "Login Attempts (5m rate)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(auth_login_total[5m]))",
          "legendFormat": "Logins/s",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Login Failures (5m rate)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(auth_login_total{outcome=\"failure\"}[5m]))",
          "legendFormat": "Failures/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "title": "Payment Initiations (5m rate)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(billing_payment_initiated_total[5m]))",
          "legendFormat": "Payments/s",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Login Success vs Failure Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(auth_login_total{outcome=\"success\"}[5m]))",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(auth_login_total{outcome=\"failure\"}[5m]))",
          "legendFormat": "Failure",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Payment Success vs Failure",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(billing_payment_completed_total{outcome=\"success\"}[5m]))",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(billing_payment_completed_total{outcome=\"failure\"}[5m]))",
          "legendFormat": "Failure",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Background Tasks Enqueued vs Completed (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(bg_tasks_enqueued_total[5m]))",
          "legendFormat": "Enqueued",
          "refId": "A"
        },
        {
          "expr": "sum(rate(bg_tasks_completed_total[5m]))",
          "legendFormat": "Completed",
          "refId": "B"
        },
        {
          "expr": "sum(rate(bg_tasks_failed_total[5m]))",
          "legendFormat": "Failed",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Document Uploads (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(documents_uploaded_total[5m])) by (category)",
          "legendFormat": "{{ category }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ecole", "business"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "title": "Business Metrics",
  "uid": "ecole-business-metrics"
}
