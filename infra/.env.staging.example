# Staging Environment Configuration
# Copy to .env.staging and fill in the values before deploying.
# NEVER commit real secrets — use Docker secrets for production-grade staging.

APP_ENV=staging
LOG_LEVEL=INFO

# ── Database (separate from production!) ──
POSTGRES_DB=ecole_platform_staging
POSTGRES_USER=ecole_staging
POSTGRES_PASSWORD=<change-me-staging-db>

# ── Redis ──
REDIS_URL=redis://redis:6379/1

# ── JWT (separate signing key from production!) ──
JWT_SECRET_KEY=<staging-specific-key-min-32-chars>
JWT_ALGORITHM=HS256

# ── CORS ──
CORS_ORIGINS=https://staging.ecole-platform.ma,http://localhost:5273

# ── Rate limiting ──
ENABLE_STRICT_RATE_LIMIT=false

# ── AI service (use mock in staging to avoid costs) ──
AI_PROVIDER=mock

# ── Monitoring ──
ENABLE_TRACING=true

# ── Seed data on startup ──
SEED_ON_STARTUP=true

# ── Grafana ──
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<change-me-grafana-staging>
