# Web environment variables (Vite — must be prefixed with VITE_)

# API proxy target for local dev
VITE_API_PROXY_TARGET=http://localhost:8000

# Sentry error tracking (leave blank to disable)
VITE_SENTRY_DSN=

# OAuth social login feature flags
VITE_GOOGLE_OAUTH_ENABLED=true
VITE_MICROSOFT_OAUTH_ENABLED=true
