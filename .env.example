# ==================== Application ====================
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=DEBUG

# ==================== Database (PostgreSQL) ====================
DATABASE_URL=postgresql+asyncpg://ecole:ecole@localhost:5432/ecole_platform
POSTGRES_USER=ecole
POSTGRES_PASSWORD=ecole
POSTGRES_DB=ecole_platform

# ==================== Cache (Redis) ====================
REDIS_URL=redis://localhost:6379/0

# ==================== Authentication (JWT) ====================
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== Timezone ====================
TZ=Africa/Casablanca

# ==================== File Uploads (Phase 3B) ====================
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=25

# ==================== SMTP / Email (Phase 3E) ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@ecole-platform.example
SMTP_PASSWORD=change-me

# ==================== Object Storage / S3 (Phase 3B) ====================
# Use MinIO locally, AWS S3 / Cloudflare R2 / DigitalOcean Spaces in production
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ecole-uploads
S3_REGION=auto

# ==================== TOTP / 2FA (Phase 2B) ====================
TOTP_ISSUER=EcolePlatform

# ==================== Feature Flags ====================
ENABLE_TRACING=false
ENABLE_STRICT_RATE_LIMIT=false
