# ==================== Application ====================
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=DEBUG

# ==================== Database (PostgreSQL) ====================
DATABASE_URL=postgresql+asyncpg://ecole:ecole@localhost:5432/ecole_platform
POSTGRES_USER=ecole
POSTGRES_PASSWORD=ecole
POSTGRES_DB=ecole_platform

# ==================== Cache (Redis) ====================
REDIS_URL=redis://localhost:6379/0

# ==================== Authentication (JWT) ====================
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== Timezone ====================
TZ=Africa/Casablanca
