# ==================== Application ====================
# Runtime environment: development | staging | production
APP_ENV=development
# FastAPI bind port
APP_PORT=8000
# Public API base URL used for signed download/preview links
API_BASE_URL=http://localhost:8000/api/v1
# Log verbosity
LOG_LEVEL=INFO

# ==================== Database (PostgreSQL) ====================
# Superuser account used by local Docker PostgreSQL
POSTGRES_USER=ecole
# Local Docker PostgreSQL password
POSTGRES_PASSWORD=change-me
# Primary application database name
POSTGRES_DB=ecole_platform
# Application role password used by infra/postgres/init.sql
APP_DB_PASSWORD=change-me
# Read-only reporting role password used by infra/postgres/init.sql
APP_READONLY_PASSWORD=change-me
# SQLAlchemy connection string used by backend and worker
DATABASE_URL=postgresql+asyncpg://ecole:change-me@localhost:5432/ecole_platform
# Optional read-only replica connection string; leave blank to reuse DATABASE_URL
DATABASE_REPLICA_URL=
# Compatibility placeholder for external tooling that expects a generic DB password variable
DATABASE_PASSWORD=change-me

# ==================== Cache (Redis) ====================
# Redis password for Docker/local environments
REDIS_PASSWORD=change-me-dev-redis
# Redis connection string used by backend and worker
REDIS_URL=redis://:change-me-dev-redis@localhost:6379/0

# ==================== Authentication (JWT) ====================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
# Optional previous signing key during the JWT rotation window
JWT_PREVIOUS_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=2

# ==================== CORS ====================
# CORS — comma-separated allowed origins
# Development: http://localhost:5173,http://localhost:3000
# Production:  https://app.ecole-platform.ma,https://admin.ecole-platform.ma
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== Timezone ====================
TZ=Africa/Casablanca

# ==================== File Uploads ====================
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=25

# ==================== SMTP / Email ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Ecole Platform

# ==================== Object Storage / MinIO + S3 ====================
# ---- Dev: self-hosted MinIO (docker-compose.dev.yml) ----------------
# MinIO admin credentials — used only in local dev.
# In staging/prod use managed S3 (AWS, R2, etc.) with IAM roles or secrets.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
# Dev-only KMS secret for SSE-S3 (must decode to exactly 32 bytes).
# NEVER reuse this value outside local development.
# Generate a real key: printf 'my-key:%s' "$(openssl rand -base64 32)"
MINIO_KMS_SECRET_KEY=ecole-dev-key:dGhpc2lzYWRldmtleWZvcmVjb2xlcGxhdGZvcm0xMjM=

# ---- Core storage backend (Phase 3B — submissions, content, exercises) ----
# Values: local (default) | s3
# Keep "local" until Phase 2 of the MinIO integration is complete.
STORAGE_BACKEND=local
# S3/MinIO connection — used when STORAGE_BACKEND=s3
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ecole-dev-private
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_FORCE_PATH_STYLE=true
# SSE-S3 server-side encryption (enabled on the bucket via minio-init; keep true in dev)
S3_SSE_ENABLED=true
# Presigned URL TTLs (seconds)
S3_PRESIGN_GET_TTL_SECONDS=600
S3_PRESIGN_PUT_TTL_SECONDS=900
# Staging/Production: point to managed S3 (no MinIO in prod)
# S3_ENDPOINT=https://s3.eu-west-1.amazonaws.com
# S3_BUCKET=ecole-prod-private
# S3_REGION=eu-west-1
# S3_ACCESS_KEY=<IAM access key or leave blank for instance role>
# S3_SECRET_KEY=<IAM secret key or leave blank for instance role>
# S3_FORCE_PATH_STYLE=false

# ---- Document storage backend (Phase 16 — student documents, resources) ----
# Values: local (default) | s3
# Keep "local" until Phase 2 of the MinIO integration is complete.
DOCUMENT_STORAGE_BACKEND=local
DOCUMENT_STORAGE_ENDPOINT=http://localhost:9000
DOCUMENT_STORAGE_BUCKET=ecole-dev-private
DOCUMENT_STORAGE_REGION=us-east-1
DOCUMENT_STORAGE_ACCESS_KEY=minioadmin
DOCUMENT_STORAGE_SECRET_KEY=minioadmin123
DOCUMENT_STORAGE_FORCE_PATH_STYLE=true
# Download presigned URL TTL (hours)
DOCUMENT_DOWNLOAD_TTL_HOURS=1

# ---- Backup (used by infra backup scripts) ---------------------------
S3_BACKUP_PREFIX=backups

# ==================== TOTP / 2FA ====================
TOTP_ISSUER=EcolePlatform

# ==================== Feature Flags ====================
ENABLE_TRACING=false
ENABLE_STRICT_RATE_LIMIT=false
OTEL_EXPORTER_ENDPOINT=http://tempo:4317

# ==================== Monitoring ====================
GRAFANA_ADMIN_USER=admin
# CHANGE THIS ON FIRST DEPLOYMENT
GRAFANA_ADMIN_PASSWORD=change-me
# Replace with your actual Slack webhook
ALERTMANAGER_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/THIS/WEBHOOK
